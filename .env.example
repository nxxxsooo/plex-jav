# Plex JAV Solution - Environment Variables
# Copy this to .env and fill in your values

# === Unraid Paths ===
# Path to your media share containing JAV input/output folders
MEDIA_PATH=/mnt/user/media/jav

# Path to Plex appdata (where Plex config lives)
PLEX_APPDATA=/mnt/user/appdata/plex

# Path to JavSP appdata (config + MetaTube database)
JAVSP_APPDATA=/mnt/user/appdata/javsp

# === Network / Proxy ===
# Set to your proxy URL if needed, or leave empty for direct connection
# Examples: http://10.0.2.88:7890  socks5://192.168.1.1:1080
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# === MetaTube (embedded in JavSP container) ===
# MetaTube provides plot/synopsis from 20+ sources including FANZA/DMM
# No API keys needed — runs inside the JavSP container automatically
METATUBE_ENABLED=1
METATUBE_TOKEN=

# === DMM Affiliate API (legacy, optional) ===
# Only needed if NOT using MetaTube. Register at https://affiliate.dmm.com/
DMM_API_ID=
DMM_AFFILIATE_ID=

# === Docker Network ===
# Unraid Docker network (default: bridge)
DOCKER_NETWORK=bridge

# === Plex ===
PLEX_CLAIM=
TZ=Asia/Shanghai
